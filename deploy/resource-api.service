[Unit]
Description=Resource Share API Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/resource-api
ExecStart=/var/www/resource-api/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
