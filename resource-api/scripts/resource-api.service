[Unit]
Description=Resource Share API Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/resource-api
ExecStart=/var/www/resource-api/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1
Environment=SECRET_KEY=change-me-to-a-strong-random-secret-key

[Install]
WantedBy=multi-user.target
